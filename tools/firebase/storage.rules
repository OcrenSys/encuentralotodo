rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /general/business-branding/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /general/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /businesses/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
