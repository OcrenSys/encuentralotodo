generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum UserRole {
    UNASSIGNED
    USER
    NO_ACCESS
    ADMIN
    SUPERADMIN
    GLOBALADMIN
}

enum BusinessAssignmentRole {
    OWNER
    MANAGER
}

enum AuthProviderType {
    MOCK
    FIREBASE
    COGNITO
}

enum SubscriptionType {
    FREE_TRIAL
    PREMIUM
    PREMIUM_PLUS
}

enum BusinessCategory {
    GENERAL_STORE
    RESTAURANT
    SERVICE
}

enum BusinessStatus {
    PENDING
    APPROVED
}

enum LeadSource {
    WHATSAPP_CLICK
    CALL_CLICK
    CONTACT_CLICK
    PROMOTION_CLICK
    PRODUCT_CLICK
}

enum LeadStatus {
    NEW
    CONTACTED
    QUALIFIED
    CLOSED
    LOST
}

enum AnalyticsEventName {
    lead_created
}

enum AuditAction {
    USER_PROFILE_UPDATED
    USER_BASE_ROLE_UPDATED
    USER_PLATFORM_ROLE_UPDATED
    USER_STATUS_UPDATED
    USER_BUSINESS_ROLE_ASSIGNED
    USER_BUSINESS_ROLE_REMOVED
    BUSINESS_OWNERSHIP_TRANSFERRED
}

model User {
    id                String             @id @default(cuid())
    fullName          String
    email             String             @unique
    role              UserRole           @default(NO_ACCESS)
    phone             String?
    avatarUrl         String?
    isActive          Boolean            @default(true)
    lastAccessAt      DateTime?
    identities        UserIdentity[]
    ownedBusinesses   Business[]         @relation("OwnedBusinesses")
    managedLinks      BusinessManager[]
    businessRoles     UserBusinessRole[]
    auditLogsAuthored AuditLog[]         @relation("AuditActor")
    auditLogsTargeted AuditLog[]         @relation("AuditTarget")
    reviews           Review[]
    createdAt         DateTime           @default(now())
    updatedAt         DateTime           @updatedAt
}

model UserIdentity {
    id             String           @id @default(cuid())
    provider       AuthProviderType
    externalUserId String
    email          String?
    emailVerified  Boolean          @default(false)
    displayName    String?
    avatarUrl      String?
    userId         String
    user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt      DateTime         @default(now())
    updatedAt      DateTime         @updatedAt

    @@unique([provider, externalUserId])
    @@index([userId])
    @@index([email])
}

model Business {
    id               String             @id @default(cuid())
    name             String
    description      String
    category         BusinessCategory
    lat              Float
    lng              Float
    zone             String
    address          String
    profileImage     String
    bannerImage      String
    subscriptionType SubscriptionType
    status           BusinessStatus     @default(PENDING)
    whatsappNumber   String
    ownerId          String
    owner            User               @relation("OwnedBusinesses", fields: [ownerId], references: [id])
    managers         BusinessManager[]
    userRoles        UserBusinessRole[]
    auditLogs        AuditLog[]
    products         Product[]
    promotions       Promotion[]
    leads            Lead[]
    reviews          Review[]
    lastUpdated      DateTime           @updatedAt
    createdAt        DateTime           @default(now())
}

model BusinessManager {
    businessId String
    userId     String
    business   Business @relation(fields: [businessId], references: [id])
    user       User     @relation(fields: [userId], references: [id])

    @@id([businessId, userId])
}

model UserBusinessRole {
    id         String                 @id @default(cuid())
    userId     String
    businessId String
    role       BusinessAssignmentRole
    user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
    business   Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
    createdAt  DateTime               @default(now())
    updatedAt  DateTime               @updatedAt

    @@unique([userId, businessId])
    @@index([userId])
    @@index([businessId])
    @@index([businessId, role])
    @@index([userId, role])
}

model AuditLog {
    id           String      @id @default(cuid())
    actorUserId  String
    targetUserId String?
    businessId   String?
    action       AuditAction
    metadata     Json?
    actorUser    User        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
    targetUser   User?       @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
    business     Business?   @relation(fields: [businessId], references: [id], onDelete: SetNull)
    createdAt    DateTime    @default(now())

    @@index([actorUserId])
    @@index([targetUserId])
    @@index([businessId])
    @@index([action])
    @@index([createdAt])
}

model Product {
    id                   String   @id @default(cuid())
    name                 String
    description          String
    images               String[]
    type                 String   @default("simple")
    configurationSummary String?
    price                Float?
    isFeatured           Boolean  @default(false)
    businessId           String
    business             Business @relation(fields: [businessId], references: [id])
    leads                Lead[]
    lastUpdated          DateTime @updatedAt
    createdAt            DateTime @default(now())
}

model Promotion {
    id            String   @id @default(cuid())
    title         String
    description   String
    type          String   @default("DISCOUNT")
    status        String   @default("DRAFT")
    promoPrice    Float
    originalPrice Float
    startDate     DateTime
    endDate       DateTime
    image         String
    businessId    String
    business      Business @relation(fields: [businessId], references: [id])
    leads         Lead[]
    updatedAt     DateTime @updatedAt
    createdAt     DateTime @default(now())
}

model Lead {
    id          String     @id @default(cuid())
    name        String?
    phone       String?
    source      LeadSource
    status      LeadStatus @default(NEW)
    summary     String
    notes       String?
    businessId  String
    productId   String?
    promotionId String?
    business    Business   @relation(fields: [businessId], references: [id])
    product     Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
    promotion   Promotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull)
    updatedAt   DateTime   @updatedAt
    createdAt   DateTime   @default(now())

    @@index([businessId, status, createdAt])
    @@index([productId])
    @@index([promotionId])
    @@index([source, createdAt])
}

model AnalyticsEvent {
    id         String             @id @default(cuid())
    name       AnalyticsEventName
    businessId String
    leadId     String?
    payload    Json
    createdAt  DateTime           @default(now())

    @@index([name, createdAt])
    @@index([businessId, createdAt])
    @@index([leadId])
}

model Review {
    id         String   @id @default(cuid())
    rating     Int
    comment    String
    userId     String
    businessId String
    user       User     @relation(fields: [userId], references: [id])
    business   Business @relation(fields: [businessId], references: [id])
    createdAt  DateTime @default(now())
}
